# ── .env.example ────────────────────────────────────────────────────────────
#
# YOUR FRIEND'S STEPS:
#   1. cp .env.example .env
#   2. Don't change anything — defaults work for demo
#
# YOUR STEPS (you already have your own .env locally):
#   Just make sure your local .env has DATABASE_HOST=localhost
#   and your friend's .env has DATABASE_HOST=db  (Docker service name)
#
# ─────────────────────────────────────────────────────────────────────────────

# ── Django settings ───────────────────────────────────────────────────────────
SECRET_KEY=django-insecure-nanbar-demo-key-2025
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,backend

# ── PostgreSQL database ───────────────────────────────────────────────────────
# These values are used by BOTH the postgres container AND Django.
# The postgres container will create a database with exactly these credentials.
# Django then connects using the same credentials.
DATABASE_NAME=nanbar_db
DATABASE_USER=nanbar_user
DATABASE_PASSWORD=nanbar_pass
DATABASE_HOST=db
DATABASE_PORT=5432

# ── Django admin account (auto-created on first docker compose up) ────────────
DJANGO_SUPERUSER_EMAIL=admin@nanbar.com
DJANGO_SUPERUSER_PASSWORD=admin123
DJANGO_SUPERUSER_NAME=Admin
